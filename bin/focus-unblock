#!/bin/bash
# focus-unblock — 临时解除屏蔽。默认有 60s 冷静等待（摩擦），--now 跳过。
# 用法: sudo focus-unblock [--now]
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HOSTS="/etc/hosts"
BEGIN="# >>> focus-guard >>>"
END="# <<< focus-guard <<<"
WAIT=60
REBLOCK_AFTER=1800
REBLOCK_LOG="/tmp/focusguard-reblock.log"
REBLOCK_TOKEN="/tmp/focusguard-reblock.token"

if [[ $EUID -ne 0 ]]; then
  echo "需要 sudo:  sudo $0" >&2
  exit 1
fi

if ! grep -qF "$BEGIN" "$HOSTS"; then
  echo "当前没有屏蔽，无需解除。"
  exit 0
fi

if [[ "${1:-}" != "--now" ]]; then
  echo "你正在解除专注屏蔽。先想 ${WAIT}s——真的现在要刷吗？(Ctrl-C 可取消)"
  for ((i=WAIT;i>0;i--)); do printf "\r  %2ds..." "$i"; sleep 1; done
  printf "\r          \n"
fi

"$ROOT/bin/_strip_block" "$HOSTS" "$BEGIN" "$END"
dscacheutil -flushcache 2>/dev/null || true
killall -HUP mDNSResponder 2>/dev/null || true

token="$(date '+%s')-$$"
printf '%s\n' "$token" > "$REBLOCK_TOKEN"
{
  printf '[%s] scheduled reblock in %ss token=%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$REBLOCK_AFTER" "$token"
} >>"$REBLOCK_LOG"
nohup bash -c '
  set -euo pipefail
  sleep "$1"
  now="$(date "+%Y-%m-%d %H:%M:%S")"
  if [[ ! -f "$3" ]]; then
    printf "[%s] skip reblock: token file missing\n" "$now"
    exit 0
  fi
  current="$(cat "$3")"
  if [[ "$current" != "$4" ]]; then
    printf "[%s] skip reblock: stale token=%s current=%s\n" "$now" "$4" "$current"
    exit 0
  fi
  printf "[%s] running focus-block token=%s\n" "$now" "$4"
  "$2/bin/focus-block"
' focusguard-reblock "$REBLOCK_AFTER" "$ROOT" "$REBLOCK_TOKEN" "$token" >>"$REBLOCK_LOG" 2>&1 &

echo "已解除屏蔽。30 分钟后会自动重新屏蔽。"
echo "自动反弹日志: $REBLOCK_LOG"
